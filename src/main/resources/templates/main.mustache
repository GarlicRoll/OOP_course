<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Title</title>
</head>
<body>
    <div>
        <form method="post">
            <input type="text" name="name" placeholder="Введите сообщение" />
            <input type="text" name="category" placeholder="Тэг">
            <button type="submit">Добавить</button>
        </form>
    </div>
    <div>Список водителей</div>
    {{#drivers}}
        <div>
        <b>{{id}}</b>
        <spab>{{name}}</spab>
        <i>{{category}}</i>
        </div>
    {{/drivers}}
</body>
</html>